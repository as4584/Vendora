# Database
DATABASE_URL=postgresql://vendora:vendora@localhost:5432/vendora
TEST_DATABASE_URL=postgresql://vendora:vendora@localhost:5433/vendora_test

# Auth
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Environment
ENVIRONMENT=development
PUBLIC_API_BASE_URL=https://vendora.lexmakesit.com/api/v1

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:8081

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRO_PRICE_ID=price_your_price_id_here

# Lightspeed Retail (R-Series) OAuth
LIGHTSPEED_CLIENT_ID=your_lightspeed_client_id_here
LIGHTSPEED_CLIENT_SECRET=your_lightspeed_client_secret_here
LIGHTSPEED_REDIRECT_URI=https://vendora.lexmakesit.com/integrations/lightspeed/callback
