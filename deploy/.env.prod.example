# Production environment configuration for Vendora
# Copy to .env.prod on the server and fill in secrets before deploying.

# Core application
SECRET_KEY=change-me
ENVIRONMENT=production
PUBLIC_API_BASE_URL=https://vendora.lexmakesit.com/api/v1

# Password reset email (SendGrid)
SENDGRID_API=
SENDGRID_FROM_EMAIL=noreply@lexmakesit.com
SENDGRID_FROM_NAME=Vendora
PASSWORD_RESET_URL=vendora://reset-password
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Database (used by backend + docker-compose)
POSTGRES_USER=vendora
POSTGRES_PASSWORD=vendora
POSTGRES_DB=vendora
DATABASE_URL=postgresql://vendora:vendora@db:5432/vendora

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Lightspeed Retail OAuth
LIGHTSPEED_CLIENT_ID=
LIGHTSPEED_CLIENT_SECRET=
LIGHTSPEED_REDIRECT_URI=https://vendora.lexmakesit.com/integrations/lightspeed/callback
