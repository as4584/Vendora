# act secrets — used by the pre-push hook when running workflows locally.
# NEVER commit this file; it is listed in .gitignore.
#
# Copy this file to .act.secrets and fill in real values:
#   Copy-Item .act.secrets.example .act.secrets
#
# Get your Expo token from:
#   https://expo.dev/accounts/<username>/settings/access-tokens

EXPO_DEV_ACCESS_TOKEN=your-expo-access-token-here
